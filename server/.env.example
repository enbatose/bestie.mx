PORT=3000
# Local: data/bestie.db  |  Railway + volume: /data/bestie.db (mount volume at /data)
DATABASE_PATH=data/bestie.db
# Comma-separated. Include every frontend origin that calls the API (local + production).
CORS_ORIGINS=http://localhost:5173,https://bestie.mx,https://www.bestie.mx
# Optional. Absolute path, or relative to server cwd. Default ../dist if index.html exists.
# Serves the Vite build from this process so POST /api/* is not blocked by static-only hosting.
# WEB_DIST_DIR=../dist
