PORT=3000
# Local: data/bestie.db  |  Railway + volume: /data/bestie.db (mount volume at /data)
DATABASE_PATH=data/bestie.db
# Comma-separated. Include every frontend origin that calls the API (local + production).
CORS_ORIGINS=http://localhost:5173,https://bestie.mx,https://www.bestie.mx
# Optional. Absolute path, or relative to server cwd. Default ../dist if index.html exists.
# Serves the Vite build from this process so POST /api/* is not blocked by static-only hosting.
# WEB_DIST_DIR=../dist

# Public web origin used for redirects after email verification and Messenger handoff links (defaults to https://bestie.mx)
# PUBLIC_WEB_ORIGIN=https://bestie.mx
#
# When the API is on a different host than the SPA (e.g. GitHub Pages + Railway), set this so verification emails
# point at the API (the verify-email route lives on the API server).
# PUBLIC_API_ORIGIN=https://your-api.up.railway.app
#
# --- Email (optional). Without SMTP, verification emails are skipped (see /api/health → smtp.configured). ---
#
# Option A — Gmail, minimal (no SMTP_HOST needed). Either pair works:
#   GMAIL_USER=you@gmail.com
#   GMAIL_APP_PASSWORD=abcd efgh ijkl mnop   # Google app password; spaces stripped
# Or the equivalent:
#   SMTP_SERVICE=gmail
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=...
#
# 1) Google Account → Security → 2-Step Verification ON
# 2) App passwords: https://support.google.com/accounts/answer/185833 → create "Mail" for this server
# 3) Optional: SMTP_PORT=465 (default) or 587; SMTP_FROM / SMTP_REPLY_TO
#
# After deploy: logs "[email] SMTP verify OK" or "FAILED"; GET /api/health → smtp.mode (gmail_implicit / …), verifyOk
#
# Option B — Any SMTP (SendGrid, Mailgun, etc.)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=...
# SMTP_FROM=Bestie <no-reply@bestie.mx>
#
# Gmail via explicit host instead of SMTP_SERVICE (same app password as above):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Bestie <you@gmail.com>
